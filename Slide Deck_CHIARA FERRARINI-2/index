<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.slide');
    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnAutoplay = document.getElementById('btnAutoplay');
    const btnAudio = document.getElementById('btnAudio');
    const iconAudio = document.getElementById('iconAudio');
    const btnFullscreen = document.getElementById('btnFullscreen');
    const hudProgress = document.getElementById('hudProgress');
    const progressBar = document.getElementById('progressBar');
    const shortcutTip = document.getElementById('shortcutTip');
    const hudControls = document.getElementById('hudControls');
    const container = document.querySelector('.deck-container');

    let currentIndex = 0;
    let autoplayInterval = null;
    let isMuted = true; // Default to muted to respect browser autoplay policies
    const autoplayDuration = 8000; // 8 seconds per slide in autoplay

    // Play synthesized warm switch click/thud sound
    function playTransitionSound() {
      if (isMuted) return;
      try {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        const ctx = new AudioContext();
        
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();
        const filter = ctx.createBiquadFilter();
        
        osc.type = 'sine';
        osc.frequency.setValueAtTime(130, ctx.currentTime); // warm low thud
        osc.frequency.exponentialRampToValueAtTime(45, ctx.currentTime + 0.14); // frequency sweep down
        
        filter.type = 'lowpass';
        filter.Q.value = 1;
        filter.frequency.setValueAtTime(250, ctx.currentTime);
        filter.frequency.exponentialRampToValueAtTime(70, ctx.currentTime + 0.14);
        
        gainNode.gain.setValueAtTime(0.08, ctx.currentTime); // quiet
        gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.14);
        
        osc.connect(filter);
        filter.connect(gainNode);
        gainNode.connect(ctx.destination);
        
        osc.start();
        osc.stop(ctx.currentTime + 0.15);
      } catch (e) {
        console.warn("Audio Context blocked or not supported", e);
      }
    }

    // 1. Navigation Logic
    function showSlide(index) {
      if (index < 0 || index >= slides.length) return;
      
      slides[currentIndex].classList.remove('active');
      currentIndex = index;
      slides[currentIndex].classList.add('active');
      
      playTransitionSound();
      
      // Update HUD
      const slideNum = String(currentIndex + 1).padStart(2, '0');
      const totalNum = String(slides.length).padStart(2, '0');
      hudProgress.textContent = `${slideNum} / ${totalNum}`;
      
      // Update progress bar
      const progressPercent = ((currentIndex + 1) / slides.length) * 100;
      progressBar.style.width = `${progressPercent}%`;

      // Trigger telemetry redraw if on slide 4
      if (currentIndex === 3) {
        const sparkline = document.querySelector('.sparkline');
        if (sparkline) {
          sparkline.style.animation = 'none';
          setTimeout(() => {
            sparkline.style.animation = '';
          }, 50);
        }
      }
    }

    function nextSlide() {
      if (currentIndex < slides.length - 1) {
        showSlide(currentIndex + 1);
      } else {
        // Loop back to first slide or stop autoplay
        if (autoplayInterval) {
          showSlide(0);
        }
      }
    }

    function prevSlide() {
      if (currentIndex > 0) {
        showSlide(currentIndex - 1);
      }
    }

    // 2. Autoplay Handler
    function toggleAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
        btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
        btnAutoplay.setAttribute('title', 'Avvio Autoplay');
      } else {
        autoplayInterval = setInterval(nextSlide, autoplayDuration);
        btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
        btnAutoplay.setAttribute('title', 'Pausa Autoplay');
      }
    }

    // 3. Fullscreen Handler
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(err => {
          console.error(`Error attempting to enable full-screen mode: ${err.message}`);
        });
      } else {
        document.exitFullscreen();
      }
    }

    // Update Fullscreen button icon based on status
    document.addEventListener('fullscreenchange', () => {
      if (document.fullscreenElement) {
        btnFullscreen.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4"/></svg>`;
      } else {
        btnFullscreen.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>`;
      }
      resizePresentation();
    });

    // 4. Viewport scaling
    function resizePresentation() {
      const targetWidth = 1280;
      const targetHeight = 720;
      const windowWidth = window.innerWidth;
      const windowHeight = window.innerHeight;
      
      const scaleX = windowWidth / targetWidth;
      const scaleY = windowHeight / targetHeight;
      
      // Scale to fit screen conserving aspects
      const scale = Math.min(scaleX, scaleY) * 0.96;
      container.style.transform = `translate(-50%, -50%) scale(${scale})`;
    }

    // 5. Setup Listeners
    btnPrev.addEventListener('click', () => {
      clearInterval(autoplayInterval);
      autoplayInterval = null;
      btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
      prevSlide();
    });

    btnNext.addEventListener('click', () => {
      clearInterval(autoplayInterval);
      autoplayInterval = null;
      btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
      nextSlide();
    });

    btnAutoplay.addEventListener('click', toggleAutoplay);
    btnFullscreen.addEventListener('click', toggleFullscreen);

    btnAudio.addEventListener('click', () => {
      isMuted = !isMuted;
      if (isMuted) {
        iconAudio.innerHTML = `<path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M23 9l-6 6m0-6l6 6"/>`;
        btnAudio.setAttribute('title', 'Attiva Audio');
      } else {
        iconAudio.innerHTML = `<path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>`;
        btnAudio.setAttribute('title', 'Disattiva Audio');
        playTransitionSound();
      }
    });

    // Keyboard bindings
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') {
        e.preventDefault();
        clearInterval(autoplayInterval);
        autoplayInterval = null;
        btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
        nextSlide();
      } else if (e.key === 'ArrowLeft' || e.key === 'Backspace') {
        e.preventDefault();
        clearInterval(autoplayInterval);
        autoplayInterval = null;
        btnAutoplay.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
        prevSlide();
      } else if (e.key.toLowerCase() === 'f') {
        toggleFullscreen();
      } else if (e.key === 'Escape' && document.fullscreenElement) {
        document.exitFullscreen();
      }
    });

    // Touch Swipe Navigation for touch displays
    let touchStartX = 0;
    let touchEndX = 0;
    
    document.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, false);

    document.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, false);

    function handleSwipe() {
      const threshold = 50;
      if (touchEndX < touchStartX - threshold) {
        nextSlide(); // Swipe left
      } else if (touchEndX > touchStartX + threshold) {
        prevSlide(); // Swipe right
      }
    }

    // Hide UI tip overlay after 4 seconds
    setTimeout(() => {
      shortcutTip.style.opacity = '0';
      setTimeout(() => shortcutTip.remove(), 600);
    }, 4500);

    // ESG Calculator Logic
    const calcTons = document.getElementById('calcTons');
    const valWater = document.getElementById('valWater');
    const valCo2 = document.getElementById('valCo2');

    function updateESGMetrics() {
      const tons = parseFloat(calcTons.value) || 0;
      // Formula: 12500 Liters of water saved per ton, 85 kg CO2 saved per ton
      const waterSaved = Math.round(tons * 12500);
      const co2Saved = Math.round(tons * 85);
      
      valWater.textContent = waterSaved.toLocaleString('it-IT');
      valCo2.textContent = co2Saved.toLocaleString('it-IT');
    }

    if (calcTons) {
      calcTons.addEventListener('input', updateESGMetrics);
      calcTons.addEventListener('change', updateESGMetrics);
    }

    // ----------------------------------------------------
    // INTERACTIVE NETWORK BACKGROUND FOR COPERTINA (SLIDE 1)
    // ----------------------------------------------------
    const netCanvas = document.getElementById('networkCanvas');
    if (netCanvas) {
      const netCtx = netCanvas.getContext('2d');
      let netWidth = netCanvas.width = 1280;
      let netHeight = netCanvas.height = 720;
      
      const numPoints = 50;
      const points = [];
      const maxDist = 120;
      
      // Initialize points
      for (let i = 0; i < numPoints; i++) {
        points.push({
          x: Math.random() * netWidth,
          y: Math.random() * netHeight,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.5 + 1
        });
      }
      
      let netMouse = { x: null, y: null };
      const s1 = document.getElementById('s1');
      
      if (s1) {
        s1.addEventListener('mousemove', (e) => {
          const rect = s1.getBoundingClientRect();
          const scaleX = rect.width / 1280;
          const scaleY = rect.height / 720;
          netMouse.x = (e.clientX - rect.left) / scaleX;
          netMouse.y = (e.clientY - rect.top) / scaleY;
        });
        
        s1.addEventListener('mouseleave', () => {
          netMouse.x = null;
          netMouse.y = null;
        });
      }

      // GLOBAL 3D PARALLAX & REACTIVE TILT FOR ALL ACTIVE SLIDES
      window.addEventListener('mousemove', (e) => {
        const activeSlide = document.querySelector('.slide.active');
        if (!activeSlide) return;
        
        const rect = activeSlide.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        const nx = x / (rect.width / 2);  // -1 .. 1
        const ny = y / (rect.height / 2); // -1 .. 1
        
        // Slide 1 (Copertina)
        if (activeSlide.id === 's1') {
          const bgParallax = activeSlide.querySelector('.bg-parallax');
          const floatLayers = activeSlide.querySelectorAll('.float-layer');
          const moveX = nx * -15;
          const moveY = ny * -15;
          if (bgParallax) {
            bgParallax.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px)) scale(1.05)`;
          }
          floatLayers.forEach(layer => {
            const depth = parseFloat(layer.dataset.depth) || 1;
            const tilt = layer.querySelector('.float-tilt');
            if (tilt) {
              const rotY = nx * 12 * depth;
              const rotX = -ny * 12 * depth;
              tilt.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
            }
          });
        }
        
        // Slide 6 (Conclusione)
        if (activeSlide.id === 's6') {
          const floatLayers = activeSlide.querySelectorAll('.float-layer');
          floatLayers.forEach(layer => {
            const depth = parseFloat(layer.dataset.depth) || 1;
            const tilt = layer.querySelector('.float-tilt');
            if (tilt) {
              const rotY = nx * 12 * depth;
              const rotX = -ny * 12 * depth;
              tilt.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
            }
          });
        }
      });
      
      function animateNetwork() {
        if (s1.classList.contains('active')) {
          netCtx.clearRect(0, 0, netWidth, netHeight);
          
          // Draw digital matrix grid
          netCtx.strokeStyle = 'rgba(45, 92, 62, 0.05)';
          netCtx.lineWidth = 0.5;
          const gridSize = 40;
          for (let x = 0; x < netWidth; x += gridSize) {
            netCtx.beginPath();
            netCtx.moveTo(x, 0);
            netCtx.lineTo(x, netHeight);
            netCtx.stroke();
          }
          for (let y = 0; y < netHeight; y += gridSize) {
            netCtx.beginPath();
            netCtx.moveTo(0, y);
            netCtx.lineTo(netWidth, y);
            netCtx.stroke();
          }
          
          // Update and draw points
          points.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            
            if (p.x < 0 || p.x > netWidth) p.vx *= -1;
            if (p.y < 0 || p.y > netHeight) p.vy *= -1;
            
            netCtx.beginPath();
            netCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            netCtx.fillStyle = 'rgba(47, 168, 160, 0.45)';
            netCtx.fill();
          });
          
          // Draw connections
          for (let i = 0; i < points.length; i++) {
            for (let j = i + 1; j < points.length; j++) {
              const p1 = points[i];
              const p2 = points[j];
              const dx = p1.x - p2.x;
              const dy = p1.y - p2.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              
              if (dist < maxDist) {
                const alpha = (1 - dist / maxDist) * 0.12;
                netCtx.strokeStyle = `rgba(45, 92, 62, ${alpha})`;
                netCtx.lineWidth = 0.8;
                netCtx.beginPath();
                netCtx.moveTo(p1.x, p1.y);
                netCtx.lineTo(p2.x, p2.y);
                netCtx.stroke();
              }
            }
          }
          
          // Connect to mouse
          if (netMouse.x !== null && netMouse.y !== null) {
            points.forEach(p => {
              const dx = p.x - netMouse.x;
              const dy = p.y - netMouse.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              
              if (dist < 160) {
                const alpha = (1 - dist / 160) * 0.25;
                netCtx.strokeStyle = `rgba(47, 168, 160, ${alpha})`;
                netCtx.lineWidth = 1.2;
                netCtx.beginPath();
                netCtx.moveTo(p.x, p.y);
                netCtx.lineTo(netMouse.x, netMouse.y);
                netCtx.stroke();
              }
            });
          }
        }
        requestAnimationFrame(animateNetwork);
      }
      
      animateNetwork();
    }

    // Initial setup
    window.addEventListener('resize', resizePresentation);
    resizePresentation();
    showSlide(0);
  });
</script>
</body>
</html>
