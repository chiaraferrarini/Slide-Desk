<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Presentazione di Tracciabilità Intelligente e Smart Farming di Mediterranei per i buyer internazionali della GDO.">
<title>Tracciabilità Intelligente e Smart Farming — Mediterranei</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:               #1A1F1C;
    --white:             #FFFFFF;
    --green-primary:     #2D5C3E;
    --green-light:       #EFF6F1;
    --green-accent:      #3D8B6F;
    --green-highlight:   #288C64; /* a beautiful mid-ground emerald teal for highlights */
    --clay:              #2FA8A0;
    --mustard:           #43BBAE;
    --cream:             #FAFAF7;
    --olive:             #8FB88A;
    --olive-deep:        #2D5C3E;
    --glass-bg:          rgba(255, 255, 255, 0.7);
    --glass-border:      rgba(45, 92, 62, 0.08);
    --card-bg:           #FAFBF9;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { 
    background: #0B130E; 
    overflow: hidden; 
    width: 100vw; 
    height: 100vh;
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-weight: 300; 
    color: var(--ink); 
  }

  /* Presentation Viewport Centering & Scaling */
  .presentation-viewport {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100vw;
    height: 100vh;
    position: relative;
  }

  .deck-container {
    width: 1280px;
    height: 720px;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transform-origin: center center;
    overflow: hidden;
    background: var(--ink);
    border-radius: 16px;
    box-shadow: 0 25px 65px rgba(0, 0, 0, 0.65);
    transition: transform 0.2s ease-out;
  }

  /* Slides Base */
  .slide {
    position: absolute;
    inset: 0;
    width: 1280px;
    height: 720px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    transform: scale(0.96) translateY(12px);
    z-index: 1;
    overflow: hidden;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1) translateY(0);
    z-index: 2;
  }

  /* SVGs blobs animations */
  .map {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .map path {
    transition: transform 12s ease-in-out;
  }
  
  @keyframes float-blob-1 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-15px, 20px) scale(1.04); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes float-blob-2 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, -15px) scale(0.96); }
    100% { transform: translate(0, 0) scale(1); }
  }
  
  .map path:nth-of-type(1) {
    animation: float-blob-1 25s ease-in-out infinite;
  }
  .map path:nth-of-type(2) {
    animation: float-blob-2 30s ease-in-out infinite;
  }

  .pad { 
    position: relative; 
    z-index: 3; 
    height: 100%; 
    padding: 50px 65px; 
    display: flex;
    flex-direction: column;
  }

  /* Text & Elements entry animations */
  .animate-fade {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .slide.active .animate-fade {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }
  .delay-4 { transition-delay: 0.4s; }
  .delay-5 { transition-delay: 0.5s; }
  .delay-6 { transition-delay: 0.6s; }

  /* Data Flow Diagram */
  .data-flow-diagram {
    margin: 38px auto;
    width: 100%;
    max-width: 900px;
    height: 70px;
    align-self: center;
  }
  .data-flow-diagram svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .data-flow-diagram .flow-line {
    animation: flow-dash 5s linear infinite;
  }
  @keyframes flow-dash {
    from { stroke-dashoffset: 220; }
    to { stroke-dashoffset: 0; }
  }

  /* Shared Typography & Elements */
  .eyebrow { 
    font-family: 'IBM Plex Mono', monospace; 
    font-size: 13px; 
    letter-spacing: 0.16em; 
    text-transform: uppercase; 
  }
  .id-text { 
    font-family: 'IBM Plex Mono', monospace; 
    font-size: 12px; 
    letter-spacing: 0.05em; 
    line-height: 1.5; 
  }
  .id-row { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    border-bottom: 1px solid rgba(26, 31, 28, 0.08);
    padding-bottom: 15px;
    margin-bottom: 20px;
  }
  h1, h2 { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-weight: 800; 
    line-height: 1.05; 
    letter-spacing: -0.03em; 
  }
  h3, p { text-wrap: pretty; }
  .pop { color: var(--green-highlight); }
  .pop-clay { color: var(--green-highlight); }

  /* Pulsing Dot Component */
  .pulse-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background-color: var(--mustard);
    border-radius: 50%;
    position: relative;
    vertical-align: middle;
    margin-right: 6px;
  }
  .pulse-dot::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid var(--mustard);
    top: -8px;
    left: -8px;
    animation: pulse-ring 1.8s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
    opacity: 0;
  }
  @keyframes pulse-ring {
    0% { transform: scale(0.3); opacity: 0.8; }
    80%, 100% { transform: scale(1); opacity: 0; }
  }

  /* SLIDE 1 — Copertina (White & Green Layout) */
 #s1 { 
  background: linear-gradient(135deg, #FAFAF7 0%, #F4FAF7 100%);
  overflow: hidden;
  position: relative;
}

#s1 .bg-parallax {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 112%;
  height: 112%;
  object-fit: cover;
  transform: translate(-50%, -50%);
  opacity: 0.06;
  pointer-events: none;
  z-index: 0;
  transition: transform 0.25s cubic-bezier(0.215, 0.610, 0.355, 1.000);
  filter: grayscale(1) contrast(1.08) brightness(1.06);
}

#s1 .pad {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 56px 72px 52px 72px;
  z-index: 5;
  position: relative;
  height: 100%;
  max-width: 700px;
}

#s1 .id-row {
  width: 100%;
  padding-bottom: 18px;
  margin-bottom: 28px;
  border-bottom: 1px solid rgba(26, 31, 28, 0.08);
}

#s1 .id-text {
  color: rgba(26, 31, 28, 0.55);
}

#s1 h1 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 64px;
  font-weight: 800;
  line-height: 0.98;
  letter-spacing: -0.045em;
  color: var(--ink);
  margin-top: 38px;
  max-width: 620px;
}

#s1 .sub {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 15px;
  font-weight: 400;
  line-height: 1.72;
  color: rgba(26, 31, 28, 0.68);
  max-width: 560px;
  margin-top: 22px;
}

#s1 .bottom-row {
  margin-top: auto;
  display: flex;
  gap: 12px;
  align-items: center;
  width: auto;
  padding-bottom: 6px;
  flex-wrap: wrap;
}

#s1 .badge {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9.5px;
  border: 1px solid rgba(26, 31, 28, 0.12);
  padding: 8px 14px;
  border-radius: 20px;
  letter-spacing: 0.05em;
  color: var(--green-primary);
  background: var(--green-light);
  font-weight: 500;
}

#s1 .holo-3d-island {
  position: absolute;
  right: 68px;
  top: 52%;
  transform: translateY(-50%) translateZ(40px);
  width: 500px;
  height: 500px;
  object-fit: contain;
  z-index: 4;
  pointer-events: none;
  filter: drop-shadow(0 25px 60px rgba(10, 82, 55, 0.08));
  transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.floating-3d-scene {
  position: absolute;
  right: 42px;
  top: 50%;
  transform: translateY(-50%);
  width: 500px;
  height: 500px;
  z-index: 4;
  pointer-events: none;
  perspective: 1600px;
}

.float-layer {
  position: absolute;
  z-index: 2;
  animation: float-bob 7s ease-in-out infinite;
}

.float-tilt {
  transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  transform-style: preserve-3d;
  will-change: transform;
  filter: drop-shadow(0 22px 38px rgba(39, 183, 176, 0.12));
}

@keyframes float-bob {
  0%, 100% { transform: translateY(0) translateZ(0); }
  50% { transform: translateY(-14px) translateZ(10px); }
}

#networkCanvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  opacity: 0.34;
}

  /* Small ambient floating icon — Slides 2-6 (quiet, corner decoration) */
  .mini-float-icon {
    position: absolute;
    top: 42px;
    right: 55px;
    z-index: 1;
    opacity: 0.16;
    pointer-events: none;
    animation: float-bob 8s ease-in-out infinite;
  }

  /* Interactive Canvas Network overlay rules */
  #networkCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    opacity: 0.55;
  }

  /* SLIDE 2 — La Sfida */
  #s2 { background: var(--green-light); }
  #s2 .id-row { border-bottom: 1px solid rgba(26, 31, 28, 0.08); }
  #s2 .id-text { color: rgba(14,27,21,0.5); }
  #s2 .eyebrow { color: var(--green-primary); }
  #s2 h2 { font-size: 44px; max-width: 800px; margin-top: 22px; color: var(--ink); }
  #s2 .rows { 
    margin-top: 65px; 
    display: flex; 
    gap: 30px; 
    width: 100%; 
    position: relative; 
    z-index: 3; 
    padding: 0 0 10px 0;
  }
  #s2 .row { 
    flex: 1;
    display: flex; 
    flex-direction: column;
    gap: 16px; 
    padding: 24px; 
    border: 1px solid rgba(14,27,21,0.08); 
    align-items: flex-start; 
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.45);
    height: auto;
  }
  #s2 .row:hover {
    background: rgba(255, 255, 255, 0.75);
    transform: translateY(-6px);
    box-shadow: 0 15px 35px rgba(10, 82, 55, 0.04);
    border-color: rgba(45, 92, 62, 0.35);
  }
  #s2 .row:last-child { border-bottom: none; }
  #s2 .row .tag-box { 
    display: flex;
    align-items: center;
    gap: 10px;
    width: auto;
  }
  #s2 .row .tag { 
    font-family: 'IBM Plex Mono', monospace; 
    font-size: 11px; 
    color: var(--green-primary); 
    letter-spacing: 0.08em; 
    font-weight: 600;
  }
  #s2 .row .icon-wrapper {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(47, 168, 160, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green-highlight);
  }
  #s2 .row h3 { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-size: 19px; 
    font-weight: 700; 
    color: var(--ink); 
    width: auto; 
    flex-shrink: initial; 
  }
  #s2 .row p { font-size: 14px; color: rgba(26,31,28,0.64); line-height: 1.54; }

  #s2 .holo-3d-box {
    position: absolute;
    right: 80px;
    top: 130px;
    width: 260px;
    height: 260px;
    object-fit: contain;
    z-index: 2;
    pointer-events: none;
    filter: drop-shadow(0 20px 40px rgba(10, 82, 55, 0.08));
    animation: float-bob 7.5s ease-in-out infinite;
  }

  /* SLIDE 3 — Il Sistema */
  #s3 { background: var(--white); }
  #s3 .id-row { border-bottom: 1px solid rgba(26, 31, 28, 0.08); }
  #s3 .id-text { color: rgba(26,31,28,0.5); }
  #s3 .eyebrow { color: var(--green-primary); }
  #s3 h2 { font-size: 44px; max-width: 660px; margin-top: 22px; color: var(--ink); }
  #s3 .lede { font-size: 16px; max-width: 800px; margin-top: 14px; color: rgba(26,31,28,0.64); line-height: 1.64; }
  
  #s3 .steps { 
    margin-top: auto; 
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 30px;
    position: relative;
    padding-top: 25px;
  }
  #s3 .steps::before {
    content: '';
    position: absolute;
    top: 55px;
    left: 40px;
    right: 40px;
    height: 1px;
    border-top: 1px dashed rgba(75, 87, 51, 0.25);
    z-index: 1;
  }
  #s3 .step { 
    background: rgba(239, 246, 241, 0.45);
    border: 1px solid rgba(45, 92, 62, 0.12);
    border-radius: 14px;
    padding: 24px;
    position: relative;
    z-index: 2;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.03);
    backdrop-filter: blur(4px);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #s3 .step:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(24, 18, 13, 0.06);
    border-color: rgba(45, 92, 62, 0.35);
    background: rgba(255, 255, 255, 0.5);
  }
  #s3 .step-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  #s3 .step .si { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-size: 32px; 
    font-weight: 800; 
    color: var(--clay); 
    opacity: 0.85; 
  }
  #s3 .step .step-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(45, 92, 62, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--olive-deep);
  }
  #s3 .step-copy h3 { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-size: 20px; 
    font-weight: 600; 
    color: var(--ink); 
    margin-bottom: 8px;
  }
  #s3 .step-copy p { 
    font-size: 14.5px; 
    color: rgba(26,31,28,0.64); 
    line-height: 1.54; 
  }

  /* SLIDE 4 — Valore GDO */
  #s4 { background: var(--green-light); }
  #s4 .id-row { border-bottom: 1px solid rgba(26, 31, 28, 0.08); }
  #s4 .id-text { color: rgba(26,31,28,0.5); }
  #s4 .eyebrow { color: var(--green-primary); }
  #s4 h2 { font-size: 44px; max-width: 660px; margin-top: 22px; color: var(--ink); }
  #s4 .split { display: flex; gap: 50px; margin-top: auto; padding-bottom: 10px; }
  #s4 .left { flex: 1.1; display: flex; flex-direction: column; justify-content: space-between; }
  #s4 .left p { font-size: 16.5px; color: rgba(26,31,28,0.64); line-height: 1.68; max-width: 530px; }
  
  #s4 .stat-row { display: flex; gap: 24px; margin-top: 25px; }
  #s4 .stat { 
    flex: 1;
    background: rgba(255, 255, 255, 0.55); 
    border: 1px solid rgba(45, 92, 62, 0.12);
    border-radius: 12px;
    padding: 16px;
  }
  #s4 .stat .v { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    font-size: 38px; 
    font-weight: 800; 
    color: var(--green-highlight); 
    line-height: 1;
  }
  #s4 .stat .l { 
    font-family: 'IBM Plex Mono', monospace; 
    font-size: 10.5px; 
    color: rgba(26,31,28,0.58); 
    margin-top: 8px; 
    line-height: 1.4; 
    letter-spacing: 0.02em; 
  }

  /* ESG Calculator */
  .esg-calculator {
    margin-top: 18px;
    background: rgba(45, 92, 62, 0.12);
    border: 1px solid rgba(45, 92, 62, 0.3);
    border-radius: 12px;
    padding: 12px 18px;
  }
  .calc-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--olive-deep);
    margin-bottom: 8px;
  }
  .calc-inputs {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  #calcTons {
    width: 80px;
    padding: 4px 8px;
    border: 1px solid rgba(24, 18, 13, 0.15);
    border-radius: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    background: white;
    outline: none;
    transition: border-color 0.2s ease;
  }
  #calcTons:focus {
    border-color: var(--green-highlight);
  }
  .calc-unit {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(26, 31, 28, 0.6);
  }
  .calc-results {
    display: flex;
    gap: 25px;
    border-top: 1px dashed rgba(26, 31, 28, 0.15);
    padding-top: 8px;
  }
  .calc-metric {
    display: flex;
    flex-direction: column;
  }
  .calc-metric .m-val {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: var(--green-highlight);
    line-height: 1.1;
  }
  .calc-metric .m-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9.5px;
    color: rgba(26, 31, 28, 0.5);
    margin-top: 2px;
  }
  
  #s4 .holo-3d-esg {
    position: absolute;
    left: 490px;
    bottom: 25px;
    width: 130px;
    height: 130px;
    object-fit: contain;
    z-index: 2;
    pointer-events: none;
    filter: drop-shadow(0 15px 30px rgba(10, 82, 55, 0.06));
    animation: float-bob 8.5s ease-in-out infinite;
  }
  
  /* Telemetry Dashboard Simulation */
  #s4 .right { 
    background: var(--ink); 
    border-radius: 20px; 
    padding: 24px 26px; 
    flex: 0.9; 
    display: flex; 
    flex-direction: column;
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(250, 250, 247, 0.06);
  }
  #s4 .right .eyebrow { color: rgba(250,250,247,0.45); margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; }
  #s4 .label-line { 
    display: flex; 
    justify-content: space-between; 
    padding: 11px 0; 
    border-bottom: 1px solid rgba(250,250,247,0.08); 
    font-size: 14.5px; 
  }
  #s4 .label-line:last-child { border-bottom: none; }
  #s4 .label-line span:first-child { color: rgba(250,250,247,0.58); }
  #s4 .label-line span:last-child { 
    font-family: 'IBM Plex Mono', monospace; 
    color: var(--mustard); 
    font-size: 12.5px; 
    font-weight: 500;
  }

  /* Telemetry graph */
  .telemetry-chart {
    height: 60px;
    margin: 12px 0 6px 0;
    position: relative;
    border-bottom: 1px dashed rgba(250, 250, 247, 0.15);
  }
  .telemetry-chart svg {
    width: 100%;
    height: 100%;
  }
  .telemetry-chart .sparkline {
    fill: none;
    stroke: var(--olive);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
  }
  .slide.active .telemetry-chart .sparkline {
    animation: draw-chart 3s ease-out forwards;
    animation-delay: 0.5s;
  }
  @keyframes draw-chart {
    to { stroke-dashoffset: 0; }
  }

  /* SLIDE 5 — Perché con noi */
  #s5 { background: var(--white); }
  #s5 .id-row { border-bottom: 1px solid rgba(26, 31, 28, 0.08); }
  #s5 .id-text { color: rgba(26,31,28,0.5); }
  #s5 .eyebrow { color: var(--green-primary); }
  #s5 h2 { font-size: 44px; max-width: 700px; margin-top: 22px; color: var(--ink); }
  #s5 .pillars { display: flex; gap: 24px; margin-top: auto; padding-top: 10px; }
  #s5 .pillar { 
    flex: 1; 
    padding: 20px; 
    background: rgba(239, 246, 241, 0.45);
    border: 1px solid rgba(45, 92, 62, 0.12);
    border-radius: 12px;
    backdrop-filter: blur(4px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #s5 .pillar:hover {
    transform: translateY(-5px);
    background: rgba(239, 246, 241, 0.75);
    border-color: rgba(45, 92, 62, 0.35);
    box-shadow: 0 15px 35px rgba(10, 82, 55, 0.05);
  }
  #s5 .pillar .n { 
    font-family: 'IBM Plex Mono', monospace; 
    font-size: 11px; 
    color: var(--green-highlight); 
    letter-spacing: 0.12em; 
    font-weight: 600;
  }
  #s5 .pillar h3 { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
